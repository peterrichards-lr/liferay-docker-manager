#!/bin/zsh

# Liferay Docker Python Wrapper (macOS/Linux)
# This script ensures a Python virtual environment (venv) is setup and runs the manager

# Get the absolute path of the script itself
# In Zsh, ${(%):-%N} gives the script path even when sourced.
# ${0:A:h} is also a reliable Zsh way to get the absolute directory.
SCRIPT_DIR=${0:A:h}

VENV_PATH="$SCRIPT_DIR/.venv"
PYTHON_SCRIPT="$SCRIPT_DIR/liferay_docker.py"
PYTHON_EXEC="python3"
CACHE_FILE="$HOME/.liferay_docker_cache.json"

# Check for clear-cache command
if [[ "$1" == "clear-cache" ]]; then
	if [ -f "$CACHE_FILE" ]; then
		rm "$CACHE_FILE"
		echo "✅ Docker tag cache cleared."
	else
		echo "ℹ Cache is already empty."
	fi
	exit 0
fi

# Check if python3 is available
if ! command -v $PYTHON_EXEC &>/dev/null; then
	echo "Error: python3 is not installed."
	exit 1
fi

# Create venv if it doesn't exist
if [ ! -d "$VENV_PATH" ]; then
	echo "Creating virtual environment in $VENV_PATH..."
	$PYTHON_EXEC -m venv "$VENV_PATH" || exit 1
	"$VENV_PATH/bin/pip" install --upgrade pip
	if [ -f "$SCRIPT_DIR/requirements.txt" ]; then
		"$VENV_PATH/bin/pip" install -r "$SCRIPT_DIR/requirements.txt"
	fi
fi

# Automated Pre-commit setup
if [ -d "$SCRIPT_DIR/.git" ] && command -v "$VENV_PATH/bin/pre-commit" &>/dev/null; then
    if [ ! -f "$SCRIPT_DIR/.git/hooks/pre-commit" ]; then
        echo "⚓ Automating local git hooks (pre-commit)..."
        "$VENV_PATH/bin/pre-commit" install &>/dev/null
    fi
fi

# Run the script using the venv's python interpreter
"$VENV_PATH/bin/python" "$PYTHON_SCRIPT" "$@"
